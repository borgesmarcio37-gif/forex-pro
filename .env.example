# ── OANDA API ─────────────────────────────────────────────────────────────────
# Obter em: https://www.oanda.com → My Account → Manage API Access

OANDA_API_TOKEN=coloca_aqui_o_token_oanda
OANDA_ACCOUNT_ID=101-xxx-xxxxxxx-xxx

# IMPORTANTE: deixa como false para demo/testes
# Só muda para true quando quiseres usar dinheiro real
OANDA_LIVE=false

# ── Anthropic API (relatórios IA) ─────────────────────────────────────────────
# Obter em: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
